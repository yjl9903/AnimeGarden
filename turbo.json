{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": [
    "UMAMI_HOST",
    "UMAMI_ID",
    "APP_HOST",
    "WEB_SERVER_URL",
    "KEEPSHARE_ID",
    "SSR_ADAPTER"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "test:ci": {
      "dependsOn": [
        "build",
        "typecheck"
      ],
      "inputs": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "format": {
      "cache": false,
      "inputs": [
        "src/**/*.{js,mjs,ts,tsx}",
        "test/**/*.{js,mjs,ts,tsx}"
      ]
    },
    "dev": {
      "cache": false
    }
  }
}